{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "plugins": {
            "da": {
              "unsafeHTML": "<p>Text goes here</p>"
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "model": "image",
          "plugins": {
            "da": {
              "name": "image",
              "type": "image",
              "fields": [
                {
                  "name": "image",
                  "selector": "img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "img[alt]"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          },
          "filter": "section",
          "model": "section"
        }
      ]
    },
    {
      "title": "Blocks",
      "id": "blocks",
      "components": [
        {
          "title": "Advanced Tabs",
          "id": "advanced-tabs",
          "model": "advanced-tabs",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"advanced-tabs\"><div><div><ul><li>Tab 1</li><li>Tab 2</li></ul></div></div></div>",
              "fields": [
                {
                  "name": "tabs",
                  "selector": "div>div>ul"
                }
              ]
            }
          }
        },
        {
          "title": "Card",
          "id": "card",
          "model": "card",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"card\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><img loading=\"lazy\" alt=\"Card image\" src=\"\"></picture></div></div><div><div><p><strong>Card Title</strong></p><p>Card description goes here.</p></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1)>div>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1)>div>picture>img[alt]"
                },
                {
                  "name": "content",
                  "selector": "div:nth-child(2)>div"
                }
              ]
            }
          }
        },
        {
          "title": "Columns",
          "id": "columns",
          "model": "columns",
          "filter": "columns",
          "plugins": {
            "da": {
              "name": "columns",
              "rows": 1,
              "columns": 2,
              "behaviour": "columns"
            }
          }
        },
        {
          "title": "Columns Row",
          "id": "columns-row",
          "model": "columns-row",
          "filter": "columns-row",
          "plugins": {
            "da": {
              "name": "columns-row",
              "behaviour": "columns-row"
            }
          }
        },
        {
          "title": "Columns Cell",
          "id": "columns-cell",
          "model": "columns-cell",
          "filter": "columns-cell",
          "plugins": {
            "da": {
              "name": "columns-cell",
              "behaviour": "columns-cell"
            }
          }
        },
        {
          "title": "Fragment",
          "id": "fragment",
          "model": "fragment",
          "plugins": {
            "da": {
              "unsafeHTML": "<p><a href=\"/fragments/\">/fragments/</a></p>",
              "fields": [
                {
                  "name": "content",
                  "selector": "div"
                }
              ]
            }
          }
        },
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"hero\"><div><div><picture><img loading=\"lazy\" alt=\"\" src=\"https://main--author-kit--aemsites.aem.live/media_1674c029fe1c222fe6f72c3bf0ad7fdf41e16eca9.jpg\"></picture></div></div><div><div><h2>Hero Heading</h2><p>Description text goes here.</p><p><em><strong><a href=\"https://example.com\">Call to Action</a></strong></em></p></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1)>picture>img[src]"
                },
                {
                  "name": "content",
                  "selector": "div:nth-child(2)>div"
                }
              ]
            }
          }
        },
        {
          "title": "Schedule",
          "id": "schedule",
          "model": "schedule",
          "plugins": {
            "da": {
              "unsafeHTML": "<p><a href=\"/schedules/\">/schedules/</a></p>",
              "fields": [
                {
                  "name": "content",
                  "selector": "a"
                }
              ]
            }
          }
        },
        {
          "title": "Table",
          "id": "table",
          "model": "table",
          "plugins": {
            "da": {
              "name": "table",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "table",
                  "selector": "div>div"
                }
              ]
            }
          }
        },
        {
          "title": "YouTube",
          "id": "youtube",
          "model": "youtube",
          "plugins": {
            "da": {
              "unsafeHTML": "<p><a href=\"https://www.youtube.com/watch?v=\">https://www.youtube.com/watch?v=</a></p>",
              "fields": [
                {
                  "name": "content",
                  "selector": "a"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "HAL shared-ui (React)",
      "id": "hal-shared-ui",
      "components": [
        {
          "title": "Button (shared-ui)",
          "id": "button",
          "model": "button",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"button\"><div><div>children</div><div>Book your cruise</div></div><div><div>variant</div><div>primary</div></div></div>",
              "fields": [
                { "name": "children", "selector": "div:nth-child(1)>div:nth-child(2)" },
                { "name": "variant", "selector": "div:nth-child(2)>div:nth-child(2)" }
              ]
            }
          }
        },
        {
          "title": "Headline (shared-ui)",
          "id": "headline",
          "model": "headline",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"headline\"><div><div>children</div><div>Headline text</div></div></div>",
              "fields": [
                { "name": "children", "selector": "div:nth-child(1)>div:nth-child(2)" }
              ]
            }
          }
        },
        {
          "title": "Savings Badge (shared-ui)",
          "id": "savings-badge",
          "model": "savings-badge",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"savings-badge\"><div><div>text</div><div>Save $200 per guest</div></div></div>",
              "fields": [
                { "name": "text", "selector": "div:nth-child(1)>div:nth-child(2)" }
              ]
            }
          }
        },
        {
          "title": "Fare Card (shared-ui)",
          "id": "fare-card",
          "model": "fare-card",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"fare-card\"><div><div>title</div><div>Have It All</div></div><div><div>badgeLabel</div><div>Best value</div></div><div><div>isBestValue</div><div>true</div></div><div><div>currency</div><div>$</div></div><div><div>price</div><div>1,299</div></div><div><div>perPersonLabel</div><div>Per person</div></div><div><div>ctaLabel</div><div>Select</div></div><div><div>secondaryLabel</div><div>See details</div></div></div>",
              "fields": [
                { "name": "title", "selector": "div:nth-child(1)>div:nth-child(2)" },
                { "name": "price", "selector": "div:nth-child(5)>div:nth-child(2)" },
                { "name": "ctaLabel", "selector": "div:nth-child(7)>div:nth-child(2)" }
              ]
            }
          }
        },
        {
          "title": "Choose Your Fare (shared-ui)",
          "id": "choose-your-fare",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"choose-your-fare\"><div><div>heading</div><div>How do you like to cruise?</div></div><div><div>description</div><div>Pick the fare that fits.</div></div><div><div>fareCards[0].id</div><div>have-it-all</div></div><div><div>fareCards[0].title</div><div>Have It All</div></div><div><div>fareCards[0].badgeLabel</div><div>Best value</div></div><div><div>fareCards[0].isBestValue</div><div>true</div></div><div><div>fareCards[0].currency</div><div>$</div></div><div><div>fareCards[0].price</div><div>1,299</div></div><div><div>fareCards[0].ctaLabel</div><div>Select Have It All</div></div><div><div>fareCards[1].id</div><div>cruise-fare</div></div><div><div>fareCards[1].title</div><div>Cruise Fare</div></div><div><div>fareCards[1].currency</div><div>$</div></div><div><div>fareCards[1].price</div><div>999</div></div><div><div>fareCards[1].ctaLabel</div><div>Select Cruise Fare</div></div></div>",
              "fields": [
                { "name": "heading", "selector": "div:nth-child(1)>div:nth-child(2)" },
                { "name": "description", "selector": "div:nth-child(2)>div:nth-child(2)" }
              ]
            }
          }
        }
      ]
    }
  ]
}